# ── Block debug / test files from public access ──────────────────────────────
<FilesMatch "^(debug_check|debug_reports|test)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Block sensitive data files ───────────────────────────────────────────────
<FilesMatch "\.(env|log|json|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Disable directory listing ─────────────────────────────────────────────────
Options -Indexes
