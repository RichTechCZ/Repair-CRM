#!/bin/sh
HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$HOOK_DIR/pre-commit-secret-scan.ps1"
fi

if command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File "$HOOK_DIR/pre-commit-secret-scan.ps1"
fi

echo "PowerShell is required for the secret scan pre-commit hook." >&2
exit 1
